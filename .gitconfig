[alias]
    # shortcuts
    st = status
    co = checkout
    br = branch
    ci = commit
    # utilities
    unstage = reset HEAD --
    last = log -1 HEAD
    amend = commit --amend --no-edit
    lg = log --graph --oneline --all --decorate
    # existing aliases
    alias = !git config --list | grep 'alias\\.' | sed 's/alias\\.\\([^=]*\\)=\\(.*\\)/\\1\\\t => \\2/' | sort
    staged = diff --cached
    delete-merged-branch = !git branch --merged | grep -v -E '\\*|master|main' | xargs git branch -d; git fetch --prune
    logp = log -p -- . ":(exclude)package-lock.json"
    aicommit = "!f() { COMMITMSG=$(claude -p 'Generate ONLY a one-line Git commit message in English, using imperative mood, summarizing what was changed and why, based strictly on the contents of `git diff --cached`. Do not add explanation or a body. Output only the commit summary line.'); git commit -m \"$COMMITMSG\" -e; }; f"
[core]
    autocrlf = false
    quotepath = false
    ignorecase = false
    excludesfile = ~/dotfiles/.gitignore_global
    attributesfile = ~/dotfiles/.gitattributes
[init]
	defaultBranch = main
[push]
    default = simple
[pull]
    rebase = merges
[rebase]
    autostash = true
[fetch]
    prune = true
[branch]
    sort = -committerdate
[rerere]
    enabled = true
[commit]
    verbose = true
[merge]
    tool = vscode
    conflictstyle = zdiff3
[mergetool]
    prompt = true
[mergetool "vscode"]
    cmd = code --wait "$MERGE"
[diff]
    tool = vscode
    algorithm = histogram
[difftool]
    prompt = false
[difftool "vscode"]
    cmd = code --wait --diff "$LOCAL" "$REMOTE"
[help]
    autocorrect = -1
[color]
    ui = auto
[ghq]
    root = ~/src